# Local SQLite (Prisma). The deployed instance also uses SQLite by default (see render.yaml).
DATABASE_URL="file:./dev.db"

# OPTIONAL cloud persistence (Turso libSQL) for the deployed instance. Not wired yet — requires
# adding the @prisma/adapter-libsql driver in lib/server/db.ts. Leave blank for SQLite.
TURSO_DATABASE_URL=""
TURSO_AUTH_TOKEN=""

# Google Gemini API (categorization, insights, Q&A). Blank = AI features fall back gracefully.
# Multiple keys supported for rotation/throughput. Use ANY of:
#   GEMINI_API_KEY (single), GEMINI_API_KEYS / GOOGLE_API_KEYS (comma-separated),
#   or GEMINI_API_KEY_1, GEMINI_API_KEY_2, ...  The client rotates on rate-limit/failure.
GEMINI_API_KEY=""
# GEMINI_API_KEYS=""
# GOOGLE_API_KEYS=""

# Optional model override (default: gemini-2.5-flash)
# GEMINI_MODEL="gemini-2.5-flash"

# Passcode gate for the deployed demo (blank = no gate, local dev only)
APP_PASSCODE=""

# Currency exchange-rate API
EXCHANGE_RATE_BASE_URL="https://open.er-api.com/v6"

# Daily cap on AI insight generation (LLM calls/day). Default 20. At the cap, insights fall
# back to a deterministic non-AI report.
INSIGHT_DAILY_LLM_CAP="20"

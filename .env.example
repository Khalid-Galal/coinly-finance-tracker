# Local SQLite (Prisma). Deployed uses TURSO_* instead.
DATABASE_URL="file:./dev.db"

# Cloud (deployed) database — leave blank for local dev
TURSO_DATABASE_URL=""
TURSO_AUTH_TOKEN=""

# Google Gemini API (categorization, insights, Q&A). Blank = AI features fall back.
GEMINI_API_KEY=""

# Passcode gate for the deployed demo (blank = no gate, local dev)
APP_PASSCODE=""

# Currency exchange-rate API
EXCHANGE_RATE_BASE_URL="https://open.er-api.com/v6"

# Hard monthly LLM spend cap (USD)
LLM_MONTHLY_CAP_USD="5"
